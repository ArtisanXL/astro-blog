---
import { Image } from "astro:assets";
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "~/components/FormattedDate.astro";
import TagPill from "~/components/TagPill.astro";
import TableOfContents from "~/components/TableOfContents.astro";
import { SITE } from "~/consts";
import type { Post } from "~/lib/posts";

interface Props {
  post: Post;
  headings: MarkdownHeading[];
  readingMinutes: number;
}

const { post, headings, readingMinutes } = Astro.props;
const { data, id } = post;

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" },
  { name: data.title, url: `/blog/${id}` },
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  image={data.ogImage}
  canonical={data.canonicalURL}
  publishedTime={data.pubDate}
  modifiedTime={data.updatedDate}
  author={data.author === "default" ? SITE.author.name : data.author}
  tags={data.tags}
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto grid w-full max-w-5xl gap-10 lg:grid-cols-[1fr_220px]" data-pagefind-body>
    <div class="min-w-0">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-[color:var(--muted)]">
        <ol class="flex flex-wrap items-center gap-2">
          {
            breadcrumbs.map((crumb, i) => (
              <li class="flex items-center gap-2">
                {i > 0 && <span aria-hidden="true">/</span>}
                {i < breadcrumbs.length - 1 ? (
                  <a href={crumb.url} class="hover:text-[color:var(--fg)]">
                    {crumb.name}
                  </a>
                ) : (
                  <span class="text-[color:var(--fg)]">{crumb.name}</span>
                )}
              </li>
            ))
          }
        </ol>
      </nav>

      <header class="mb-8 space-y-4">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl" data-pagefind-meta="title">
          {data.title}
        </h1>
        <p class="text-lg text-[color:var(--muted)]">{data.description}</p>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[color:var(--muted)]">
          <span>
            By <span class="font-medium text-[color:var(--fg)]">
              {data.author === "default" ? SITE.author.name : data.author}
            </span>
          </span>
          <span aria-hidden="true">·</span>
          <FormattedDate date={data.pubDate} />
          {
            data.updatedDate && (
              <>
                <span aria-hidden="true">·</span>
                <span>
                  Updated <FormattedDate date={data.updatedDate} format="short" />
                </span>
              </>
            )
          }
          <span aria-hidden="true">·</span>
          <span>{readingMinutes} min read</span>
        </div>
        {
          data.tags.length > 0 && (
            <ul class="flex flex-wrap gap-1.5 pt-2">
              {data.tags.map((tag) => (
                <li>
                  <TagPill tag={tag} />
                </li>
              ))}
            </ul>
          )
        }
      </header>

      {
        data.heroImage && (
          <figure class="mb-10 overflow-hidden rounded-xl border border-[color:var(--border)]">
            <Image
              src={data.heroImage}
              alt={data.heroImageAlt ?? ""}
              widths={[480, 800, 1200, 1600]}
              sizes="(min-width: 1024px) 768px, 100vw"
              loading="eager"
              fetchpriority="high"
              class="w-full"
            />
            {data.heroImageAlt && (
              <figcaption class="bg-slate-50 px-4 py-2 text-center text-xs text-[color:var(--muted)] dark:bg-slate-900">
                {data.heroImageAlt}
              </figcaption>
            )}
          </figure>
        )
      }

      <div class="prose">
        <slot />
      </div>

      <footer class="mt-16 border-t border-[color:var(--border)] pt-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-medium text-[color:var(--muted)] transition hover:text-[color:var(--fg)]"
          >
            <span aria-hidden="true">←</span> All posts
          </a>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(data.title)}&url=${encodeURIComponent(new URL(`/blog/${id}`, SITE.url).toString())}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-md border border-[color:var(--border)] px-3 py-1.5 text-sm font-medium transition hover:border-brand-500 hover:text-brand-600"
          >
            Share on Twitter
          </a>
        </div>
      </footer>
    </div>

    <TableOfContents headings={headings} />
  </article>
</BaseLayout>
