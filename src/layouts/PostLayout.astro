---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Tag from "~/components/Tag.astro";
import RelatedPosts from "~/components/RelatedPosts.astro";
import { SITE, BRAND } from "~/consts";
import { formatDateLong } from "~/lib/format";
import {
  type Post,
  estimateReadingTime,
  getPostSlug,
  getPostUrl,
  getPublishedPosts,
} from "~/lib/posts";
import { type Locale, useTranslations, localePath } from "~/i18n";
import { buildPostGraph, postOgImageUrl } from "~/lib/schema";
import { findRelated } from "~/lib/related";
import { getTopicsForPost } from "~/lib/topics";

interface Props {
  post: Post;
  locale: Locale;
  prev?: Post;
  next?: Post;
  /** Slug of the counterpart post in the other locale, if it exists. */
  altSlug?: string;
}

const { post, locale, prev, next, altSlug } = Astro.props;
const t = useTranslations(locale);
const rt = estimateReadingTime(post.body);
const slug = getPostSlug(post);
const altPath = altSlug ? `/blog/${altSlug}/` : "/blog/";
const blogHref = localePath(locale, "/blog");
const homeHref = localePath(locale, "/");

// Topic membership — rendered as small "Part of:" rosettes under the title.
const postTopics = getTopicsForPost(post);
const topicLinks = postTopics.map((slug) => ({
  slug,
  title: t.topics[slug].title,
  href: localePath(locale, `/topics/${slug}`),
}));

// Related posts via tag Jaccard similarity (top 3, same locale).
const allPosts = await getPublishedPosts(locale);
const related = findRelated(post, allPosts, 3).map((r) => r.post);

// Canonical: explicit override from frontmatter wins; otherwise current URL.
const siteOrigin = Astro.site ?? new URL(SITE.url);
const defaultCanonical = new URL(Astro.url.pathname, siteOrigin).toString();
const canonicalURL = post.data.canonical ?? defaultCanonical;
const ogImage = postOgImageUrl(post);

// Structured data — BreadcrumbList + WebPage + BlogPosting in one @graph.
const jsonLd = buildPostGraph(post, {
  canonicalUrl: canonicalURL,
  imageUrl: ogImage,
  locale,
  breadcrumb: [
    { name: t.nav.home, url: new URL(homeHref, siteOrigin).toString() },
    { name: t.nav.blog, url: new URL(blogHref, siteOrigin).toString() },
    { name: post.data.title, url: canonicalURL },
  ],
});
---

<BaseLayout
  locale={locale}
  title={`${post.data.title} · ${BRAND}`}
  description={post.data.description}
  image={ogImage}
  canonicalURL={canonicalURL}
  altPath={altPath}
  noindex={post.data.noindex}
  jsonLd={jsonLd}
>
  <div class="post-header">
    <div class="shell">
      <div class="breadcrumbs">
        <a href={homeHref}>~</a>
        <span>/</span>
        <a href={blogHref}>{t.post.breadcrumbBlog}</a>
        <span>/</span>
        <span style="color: var(--fg);">{slug}</span>
      </div>
      <div style="display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap;">
        {post.data.tags.map((tg) => <Tag slug={tg} locale={locale} />)}
      </div>
      {topicLinks.length > 0 && (
        <div
          style="display: flex; gap: 12px; align-items: baseline; margin-bottom: 14px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 11px; color: var(--muted);"
        >
          <span style="letter-spacing: 0.05em; text-transform: uppercase;">{t.post.partOf}</span>
          {topicLinks.map((tp) => (
            <a
              href={tp.href}
              style="color: var(--muted); border-bottom: 1px solid var(--border); padding-bottom: 1px;"
            >
              {tp.title}
            </a>
          ))}
        </div>
      )}
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
      <div class="post-meta">
        <span class="author">
          <span class="avatar">{SITE.author.initials}</span>
          {SITE.author.name}
        </span>
        <span>·</span>
        <span>{formatDateLong(post.data.pubDate, locale)}</span>
        <span>·</span>
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          {rt.minutes} {t.post.readingMinutes}
        </span>
      </div>
    </div>
  </div>

  <div class="shell">
    <div class="post-body">
      <article class="prose" id="prose">
        <slot />
      </article>

      <aside class="toc" id="toc">
        <h5>{t.post.toc}</h5>
        <ul id="toc-list"></ul>
        <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border);">
          <h5>{t.post.share}</h5>
          <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13px; color: var(--muted);">
            <a id="share-twitter" href="#" target="_blank" rel="noreferrer" style="color: var(--muted);">{t.post.shareTwitter}</a>
            <button
              id="share-copy"
              class="btn-ghost"
              data-copy={t.post.shareCopy}
              data-copied={t.post.shareCopied}
              style="background: none; border: none; color: var(--muted); cursor: pointer; padding: 0; text-align: left; font: inherit;"
            >{t.post.shareCopy}</button>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <RelatedPosts posts={related} locale={locale} />

  <div class="shell">
    <div class="post-foot">
      <div class="post-foot-grid">
        <a class="foot-link" href={prev ? getPostUrl(prev) : blogHref} style={prev ? "" : "opacity: 0.4;"}>
          <span class="lbl">{t.post.prev}</span>
          <h4>{prev ? prev.data.title : t.post.atStart}</h4>
        </a>
        <a class="foot-link next" href={next ? getPostUrl(next) : blogHref} style={next ? "" : "opacity: 0.4;"}>
          <span class="lbl">{t.post.next}</span>
          <h4>{next ? next.data.title : t.post.atEnd}</h4>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  function bindPostLayout() {
    // Build TOC from H2's
    const prose = document.getElementById("prose");
    const tocList = document.getElementById("toc-list");
    if (!prose || !tocList) return;
    const headings = prose.querySelectorAll("h2");
    tocList.innerHTML = "";
    headings.forEach((h) => {
      if (!h.id) h.id = h.textContent.toLowerCase().replace(/[^\w]+/g, "-").replace(/^-|-$/g, "");
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = "#" + h.id;
      a.textContent = h.textContent;
      a.dataset.tocFor = h.id;
      li.appendChild(a);
      tocList.appendChild(li);
    });

    function onScroll() {
      let active = "";
      headings.forEach((h) => {
        if (h.getBoundingClientRect().top < 120) active = h.id;
      });
      tocList.querySelectorAll("li").forEach((li) => {
        const a = li.querySelector("a");
        li.classList.toggle("active", a && a.dataset.tocFor === active);
      });
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Share
    const url = location.href;
    const title = document.title;
    const tw = document.getElementById("share-twitter");
    if (tw) tw.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
    const copy = document.getElementById("share-copy");
    if (copy && !copy.dataset.bound) {
      copy.dataset.bound = "1";
      const labelIdle = copy.dataset.copy || copy.textContent;
      const labelDone = copy.dataset.copied || labelIdle;
      copy.addEventListener("click", () => {
        navigator.clipboard?.writeText(url);
        copy.textContent = labelDone;
        setTimeout(() => (copy.textContent = labelIdle), 1400);
      });
    }
  }
  bindPostLayout();
  document.addEventListener("astro:after-swap", bindPostLayout);
</script>
