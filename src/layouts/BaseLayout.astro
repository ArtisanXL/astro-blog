---
import "~/styles/global.css";
import BaseHead from "~/components/BaseHead.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { type Locale, useTranslations } from "~/i18n";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  /** Counterpart path in the other locale, used by the language switcher and hreflang. */
  altPath?: string;
}

const { locale, title, description, image, canonicalURL, altPath } = Astro.props;
const t = useTranslations(locale);
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <BaseHead
      locale={locale}
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      altPath={altPath}
    />
  </head>
  <body>
    <a href="#content" class="skip-link">{t.skipLink}</a>
    <Header locale={locale} altPath={altPath} />
    <main id="content">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
