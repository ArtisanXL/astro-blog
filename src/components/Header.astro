---
import { SITE } from "~/consts";
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
---

<header class="sticky top-0 z-40 border-b border-[color:var(--border)] bg-[color:var(--bg)]/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="group flex items-center gap-2 font-semibold tracking-tight">
      <span class="grid h-8 w-8 place-items-center rounded-md bg-brand-500 text-white transition group-hover:bg-brand-600">
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M4 12c4-8 12-8 16 0M4 12c4 8 12 8 16 0" />
        </svg>
      </span>
      <span class="hidden sm:inline">{SITE.title.split("—")[0].trim()}</span>
    </a>

    <nav aria-label="Primary" class="flex items-center gap-1 text-sm font-medium">
      {
        SITE.navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "rounded-md px-3 py-1.5 transition",
              isActive(link.href)
                ? "bg-slate-100 text-slate-900 dark:bg-slate-800 dark:text-slate-100"
                : "text-[color:var(--muted)] hover:text-[color:var(--fg)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
