---
import { SITE, NAV_KEYS, NAV_PATHS } from "~/consts";
import { type Locale, useTranslations, localePath } from "~/i18n";
import { TOPIC_SLUGS } from "~/lib/topics";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const navLinks = NAV_KEYS.map((key) => ({
  key,
  href: localePath(locale, NAV_PATHS[key]),
  label: t.nav[key],
}));

const topicLinks = TOPIC_SLUGS.map((slug) => ({
  slug,
  href: localePath(locale, `/topics/${slug}`),
  label: t.topics[slug].title,
}));
---

<footer class="footer">
  <div class="shell">
    <div class="footer-grid">
      <div>
        <a href={localePath(locale, "/")} class="brand">
          <span class="brand-mark accent">m</span>
          <span>mert<span class="brand-host">.gg</span></span>
        </a>
        <p
          style="color: var(--muted); margin-top: 14px; max-width: 38ch; font-size: 14px; line-height: 1.6;"
        >
          {t.rss.description}
        </p>
      </div>
      <div>
        <h4>{t.footer.pages}</h4>
        <div class="footer-list">
          {navLinks.map((n) => <a href={n.href}>{n.label}</a>)}
        </div>
      </div>
      <div>
        <h4>
          <a href={localePath(locale, "/topics")}>{t.topicsIndex.title}</a>
        </h4>
        <div class="footer-list">
          {topicLinks.map((tp) => <a href={tp.href}>{tp.label}</a>)}
        </div>
      </div>
      <div>
        <h4>{t.footer.connect}</h4>
        <div class="footer-list">
          <a href={SITE.author.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href={SITE.author.twitter} target="_blank" rel="noreferrer">Twitter</a>
          <a href={SITE.author.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={`mailto:${SITE.author.email}`}>{SITE.author.email}</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>
        © {new Date().getFullYear()}
        {SITE.author.name} · {t.footer.copyrightSuffix}
      </span>
      <span>v6.3.3</span>
    </div>
  </div>
</footer>
