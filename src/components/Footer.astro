---
import { SITE } from "~/consts";
---

<footer class="footer">
  <div class="shell">
    <div class="footer-grid">
      <div>
        <a href="/" class="brand">
          <span class="brand-mark accent">m</span>
          <span>mert<span class="brand-host">.gg</span></span>
        </a>
        <p style="color: var(--muted); margin-top: 14px; max-width: 38ch; font-size: 14px; line-height: 1.6;">
          Edge'de Laravel, paket geliştirme ve gönderme zanaatı üzerine notlar.
        </p>
      </div>
      <div>
        <h4>Sayfalar</h4>
        <div class="footer-list">
          {SITE.navLinks.map((n) => <a href={n.href}>{n.label}</a>)}
        </div>
      </div>
      <div>
        <h4>Bağlantı</h4>
        <div class="footer-list">
          <a href={SITE.author.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href={SITE.author.twitter} target="_blank" rel="noreferrer">Twitter</a>
          <a href={SITE.author.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={`mailto:${SITE.author.email}`}>{SITE.author.email}</a>
        </div>
      </div>
      <div>
        <h4>Kolofon</h4>
        <div class="footer-list" style="color: var(--muted); font-size: 13.5px; line-height: 1.6;">
          <span>Astro 6 · Cloudflare Workers</span>
          <span>Geist · JetBrains Mono</span>
          <span>Türkiye'den, edge'den</span>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} {SITE.author.name} · Tüm yazılar CC BY 4.0</span>
      <span>v6.3.3</span>
    </div>
  </div>
</footer>
