---
import { SITE } from "~/consts";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[color:var(--border)]">
  <div class="mx-auto flex max-w-5xl flex-col items-start gap-6 px-4 py-10 sm:flex-row sm:items-center sm:justify-between sm:px-6">
    <div class="text-sm text-[color:var(--muted)]">
      <p class="font-medium text-[color:var(--fg)]">{SITE.author.name}</p>
      <p>© {year} · Built on the edge with Astro + Cloudflare Workers.</p>
    </div>
    <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
      {
        SITE.social.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-[color:var(--muted)] transition hover:text-[color:var(--fg)]"
              rel={link.href.startsWith("http") ? "me noopener" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
