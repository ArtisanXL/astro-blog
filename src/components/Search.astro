---
// Pagefind-powered, client-side search. The index is generated post-build
// (see package.json scripts). At runtime we lazy-load pagefind only when the
// user actually focuses the search box, keeping initial JS at zero.
---

<div class="not-prose" data-pagefind-root>
  <label for="pagefind-input" class="sr-only">Search posts</label>
  <input
    id="pagefind-input"
    type="search"
    placeholder="Search posts…"
    autocomplete="off"
    spellcheck="false"
    class="w-full rounded-lg border border-[color:var(--border)] bg-transparent px-4 py-3 text-base shadow-sm transition focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30"
  />
  <div id="pagefind-results" class="mt-6 space-y-4" aria-live="polite"></div>
</div>

<script>
  const input = document.getElementById("pagefind-input") as HTMLInputElement | null;
  const results = document.getElementById("pagefind-results");
  if (input && results) {
    let pagefindPromise: Promise<any> | null = null;

    // Pagefind is added to /pagefind/ after build by the `pagefind --site dist`
    // step in `npm run build`. Hide the import from Rollup with `new Function`
    // so it's not analyzed and externalized at build time.
    const dynamicImport = new Function("path", "return import(path)") as (p: string) => Promise<any>;
    const loadPagefind = () => {
      if (!pagefindPromise) {
        pagefindPromise = dynamicImport("/pagefind/pagefind.js").then(async (m) => {
          await m.options({ excerptLength: 30 });
          return m;
        });
      }
      return pagefindPromise;
    };

    const escapeHTML = (s: string) =>
      s.replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!,
      );

    let token = 0;
    const search = async (query: string) => {
      const current = ++token;
      if (!query.trim()) {
        results.innerHTML = "";
        return;
      }
      try {
        const pagefind = await loadPagefind();
        const search = await pagefind.search(query);
        if (current !== token) return;
        if (!search.results.length) {
          results.innerHTML = `<p class="text-sm text-[color:var(--muted)]">No matches for "${escapeHTML(query)}".</p>`;
          return;
        }
        const top = await Promise.all(search.results.slice(0, 10).map((r: any) => r.data()));
        if (current !== token) return;
        results.innerHTML = top
          .map(
            (r: any) => `
              <a href="${r.url}" class="block rounded-lg border border-[color:var(--border)] p-4 transition hover:border-brand-500/60">
                <h3 class="font-semibold tracking-tight">${escapeHTML(r.meta.title ?? r.url)}</h3>
                <p class="mt-1 text-sm text-[color:var(--muted)]">${r.excerpt}</p>
              </a>
            `,
          )
          .join("");
      } catch (err) {
        results.innerHTML = `<p class="text-sm text-[color:var(--muted)]">Search index not available yet — run <code>npm run build</code>.</p>`;
        // eslint-disable-next-line no-console
        console.error(err);
      }
    };

    let timer: number;
    input.addEventListener("input", () => {
      clearTimeout(timer);
      timer = window.setTimeout(() => search(input.value), 120);
    });
    // Preload on first focus.
    input.addEventListener("focus", () => loadPagefind(), { once: true });

    // Honor ?q= for deep linking from sitelinks searchbox.
    const q = new URL(location.href).searchParams.get("q");
    if (q) {
      input.value = q;
      search(q);
    }
  }
</script>
