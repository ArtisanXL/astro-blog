---
import { SITE } from "~/consts";
import { type Locale, useTranslations, localePath, LOCALES } from "~/i18n";
import { buildPersonEntity, buildWebSiteEntity } from "~/lib/schema";
import JsonLd from "~/components/JsonLd.astro";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  /** Counterpart pathname (without locale prefix) for hreflang. */
  altPath?: string;
  /** Hide the page from search engines. Adds `noindex, nofollow`. */
  noindex?: boolean;
  /** Page-specific JSON-LD entities — merged into the global @graph. */
  jsonLd?: object[];
}

const t = useTranslations(Astro.props.locale);
const {
  locale,
  title = SITE.title,
  description = t.rss.description,
  image = SITE.ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString(),
  altPath,
  noindex = false,
  jsonLd = [],
} = Astro.props;

const siteOrigin = Astro.site ?? new URL(SITE.url);
// `altPath` is the path (no locale prefix) of this page in the OTHER locale.
// For most pages the slug is the same in both locales (e.g. `/about`); for
// posts it differs, hence the explicit prop.
const alternates = altPath
  ? LOCALES.map((l) => ({
      locale: l,
      href:
        l === locale
          ? new URL(Astro.url.pathname, siteOrigin).toString()
          : new URL(localePath(l, altPath), siteOrigin).toString(),
    }))
  : null;
const trPath =
  altPath == null
    ? null
    : locale === "tr"
      ? Astro.url.pathname
      : localePath("tr", altPath);
const xDefaultHref = trPath ? new URL(trPath, siteOrigin).toString() : null;

// Always-on global entities. Pages can append more via the `jsonLd` prop.
const graph: object[] = [buildWebSiteEntity(locale), buildPersonEntity(), ...jsonLd];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content={SITE.themeColor} />
<meta
  name="robots"
  content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"}
/>
<link rel="canonical" href={canonicalURL} />

<!-- Icons / PWA -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

{alternates?.map((a) => <link rel="alternate" hreflang={a.locale} href={a.href} />)}
{xDefaultHref && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={new URL(image, siteOrigin).toString()} />
<meta property="og:locale" content={t.ogLocale} />
<meta property="og:site_name" content={SITE.title} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, siteOrigin).toString()} />

<!-- Feeds -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.title} (${locale.toUpperCase()})`}
  href={`/${locale}/rss.xml`}
/>

<!-- Structured data — combined @graph (WebSite + Person + page entities) -->
<JsonLd graph={graph} />

<!-- Theme — set before paint to avoid flash. Wrapped in try/catch because
     localStorage throws under Safari private-mode + some embed contexts. -->
<script is:inline>
  (function () {
    try {
      const saved = localStorage.getItem("mertgg-theme");
      const initial =
        saved || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.classList.toggle("dark", initial === "dark");
    } catch (_) {
      // Fall back to system preference without persisting.
      if (matchMedia("(prefers-color-scheme: dark)").matches) {
        document.documentElement.classList.add("dark");
      }
    }
  })();
</script>
