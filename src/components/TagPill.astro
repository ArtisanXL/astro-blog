---
import { slugify } from "~/lib/posts";

interface Props {
  tag: string;
  count?: number;
  size?: "sm" | "md";
}

const { tag, count, size = "sm" } = Astro.props;
const href = `/tags/${slugify(tag)}`;
---

<a
  href={href}
  class:list={[
    "inline-flex items-center gap-1.5 rounded-full border border-[color:var(--border)] font-medium text-[color:var(--muted)] transition hover:border-brand-500 hover:text-brand-600 dark:hover:text-brand-400",
    size === "sm" ? "px-2.5 py-0.5 text-xs" : "px-3 py-1 text-sm",
  ]}
>
  <span aria-hidden="true">#</span>
  <span>{tag}</span>
  {count !== undefined && <span class="text-[color:var(--muted)]/70">({count})</span>}
</a>
