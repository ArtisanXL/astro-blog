---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}

const items = Astro.props.headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 2 && (
    <aside class="hidden lg:block" aria-label="Table of contents">
      <nav class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto text-sm">
        <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-[color:var(--muted)]">
          On this page
        </p>
        <ul class="space-y-1.5">
          {items.map((heading) => (
            <li class={heading.depth === 3 ? "pl-4" : ""}>
              <a
                href={`#${heading.slug}`}
                class="block text-[color:var(--muted)] transition hover:text-brand-600 dark:hover:text-brand-400"
                data-toc-link={heading.slug}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<script>
  // Highlight the currently visible heading using IntersectionObserver.
  const init = () => {
    const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
    if (links.length === 0) return;
    const headings = Array.from(links)
      .map((link) => document.getElementById(link.dataset.tocLink!))
      .filter((el): el is HTMLElement => !!el);

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          links.forEach((l) => l.classList.remove("text-brand-600", "dark:text-brand-400", "font-semibold"));
          const active = document.querySelector(`[data-toc-link="${entry.target.id}"]`);
          active?.classList.add("text-brand-600", "dark:text-brand-400", "font-semibold");
        }
      },
      { rootMargin: "-80px 0px -70% 0px" },
    );

    headings.forEach((h) => observer.observe(h));
  };
  init();
  document.addEventListener("astro:after-swap", init);
</script>
