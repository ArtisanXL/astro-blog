---
// Toggle butonu — açık/koyu temayı saklar.
---

<button id="theme-toggle" class="icon-btn" aria-label="Tema değiştir" title="Tema değiştir">
  <svg class="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
  <svg class="moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
  </svg>
</button>

<script is:inline>
  function setTheme(t) {
    document.documentElement.classList.toggle("dark", t === "dark");
    localStorage.setItem("mertgg-theme", t);
    document.querySelectorAll("#theme-toggle .sun").forEach((s) => (s.style.display = t === "dark" ? "none" : "block"));
    document.querySelectorAll("#theme-toggle .moon").forEach((m) => (m.style.display = t === "dark" ? "block" : "none"));
  }
  function bindToggle() {
    const t = localStorage.getItem("mertgg-theme") || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    setTheme(t);
    const btn = document.getElementById("theme-toggle");
    if (btn && !btn.dataset.bound) {
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {
        const cur = document.documentElement.classList.contains("dark") ? "dark" : "light";
        setTheme(cur === "dark" ? "light" : "dark");
      });
    }
  }
  bindToggle();
  document.addEventListener("astro:after-swap", bindToggle);
</script>
