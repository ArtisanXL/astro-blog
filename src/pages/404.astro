---
export const prerender = true;

import BaseLayout from "~/layouts/BaseLayout.astro";
import { DEFAULT_LOCALE, useTranslations, localePath } from "~/i18n";

const locale = DEFAULT_LOCALE;
const t = useTranslations(locale);
---

<BaseLayout locale={locale} title={t.notFound.title} description={t.notFound.descriptionMeta}>
  <section class="shell" style="padding: 96px 0;">
    <div style="max-width: 36rem;">
      <span class="eyebrow">{t.notFound.eyebrow}</span>
      <h1 style="margin-top: 12px;">{t.notFound.heading}</h1>
      <p
        style="color: var(--muted); margin-top: 16px; line-height: 1.6;"
        set:html={t.notFound.bodyHtml(localePath(locale, "/"), localePath(locale, "/blog"))}
      />
    </div>
  </section>
</BaseLayout>
