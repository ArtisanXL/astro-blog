---
export const prerender = true;

import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout title="404 · Sayfa bulunamadı" description="Aradığın sayfa burada değil.">
  <section class="shell" style="padding: 96px 0;">
    <div style="max-width: 36rem;">
      <span class="eyebrow">/404 — yok böyle bir sayfa</span>
      <h1 style="margin-top: 12px;">Burada bir şey yok.</h1>
      <p style="color: var(--muted); margin-top: 16px; line-height: 1.6;">
        Aradığın sayfa taşınmış, silinmiş ya da hiç var olmamış olabilir.
        Sıfırdan başlamak istersen <a href="/">ana sayfaya</a> dönebilir,
        ya da <a href="/blog">arşive</a> göz atabilirsin.
      </p>
    </div>
  </section>
</BaseLayout>
