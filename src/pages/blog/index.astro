---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostRow from "~/components/PostRow.astro";
import { getPublishedPosts, getAllTags } from "~/lib/posts";
import { tagLabel, BRAND } from "~/consts";

export const prerender = true;

const posts = await getPublishedPosts();
const tagCounts = await getAllTags();
const topTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);
---

<BaseLayout title={`Yazılar · ${BRAND}`} description="Tüm yazılar — Laravel, edge ve mimari notları.">
  <section class="blog-head">
    <div class="shell">
      <span class="eyebrow">/yazılar — {posts.length} adet</span>
      <h1>Arşiv</h1>
      <p>Yazdığım her şey burada. Etiketle daralt, başlıkta ara, ya da sadece kaydırarak gez.</p>
    </div>
  </section>

  <div class="shell">
    <div class="filter-bar" id="filter-bar">
      <div class="filter-chips">
        <button class="tag active" data-filter-tag="" type="button">Hepsi · {posts.length}</button>
        {topTags.map(([slug, n]) => (
          <button class="tag" data-filter-tag={slug} type="button">{tagLabel(slug)} · {n}</button>
        ))}
        <a href="/tags" class="tag" style="border-style: dashed;">hepsi →</a>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <div class="search-box">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
          <input id="search-input" type="search" placeholder="Başlık veya etikette ara..." />
          <kbd>⌘K</kbd>
        </div>
      </div>
    </div>

    <div class="postlist" id="postlist" style="padding-bottom: 64px;">
      {posts.map((p, i) => (
        <PostRow
          post={p}
          index={i}
          data-tags={p.data.tags.join(",")}
          data-title={p.data.title.toLowerCase()}
        />
      ))}
    </div>
    <div id="empty-state" class="empty" style="display: none;">// 0 sonuç. Aramayı değiştir veya filtreyi kaldır.</div>
  </div>
</BaseLayout>

<script is:inline>
  function bindBlogFilter() {
    const input = document.getElementById("search-input");
    const rows = Array.from(document.querySelectorAll("#postlist .postrow"));
    const chips = document.querySelectorAll("[data-filter-tag]");
    const empty = document.getElementById("empty-state");
    if (!input || !rows.length) return;

    let activeTag = "";
    let q = "";

    function apply() {
      let visible = 0;
      rows.forEach((row) => {
        const tags = (row.dataset.tags || "").split(",");
        const title = (row.dataset.title || "") + " " + tags.join(" ");
        const matchTag = !activeTag || tags.includes(activeTag);
        const matchQ = !q || title.toLowerCase().includes(q.toLowerCase());
        const show = matchTag && matchQ;
        row.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? "" : "none";
    }

    input.addEventListener("input", (e) => { q = e.target.value; apply(); });
    chips.forEach((c) => {
      c.addEventListener("click", () => {
        const t = c.dataset.filterTag || "";
        activeTag = activeTag === t ? "" : t;
        chips.forEach((cc) => cc.classList.toggle("active", (cc.dataset.filterTag || "") === activeTag || (!activeTag && (cc.dataset.filterTag || "") === "")));
        apply();
      });
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        input.focus();
      }
    });
  }
  bindBlogFilter();
  document.addEventListener("astro:after-swap", bindBlogFilter);
</script>
