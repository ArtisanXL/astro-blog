---
export const prerender = true;

import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import PostLayout from "~/layouts/PostLayout.astro";
import { getPublishedPosts, estimateReadingTime, type Post } from "~/lib/posts";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
};

type Props = { post: Post };

const { post } = Astro.props as Props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
const stats = estimateReadingTime(post.body);
const readingMinutes = (remarkPluginFrontmatter?.minutesRead as number | undefined) ?? stats.minutes;
---

<PostLayout post={post} headings={headings} readingMinutes={readingMinutes}>
  <Content />
</PostLayout>
