---
export const prerender = true;

import type { GetStaticPaths } from "astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostCard from "~/components/PostCard.astro";
import { getPublishedPosts, type Post } from "~/lib/posts";
import { SITE } from "~/consts";

interface PageProp {
  data: Post[];
  currentPage: number;
  lastPage: number;
  total: number;
  prev: string | null;
  next: string | null;
}

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedPosts();
  const size = SITE.postsPerPage;
  const lastPage = Math.max(1, Math.ceil(posts.length / size));

  // Pages 2..lastPage live here; page 1 is served by /blog/index.astro.
  const paths = [];
  for (let n = 2; n <= lastPage; n++) {
    const start = (n - 1) * size;
    paths.push({
      params: { page: String(n) },
      props: {
        page: {
          data: posts.slice(start, start + size),
          currentPage: n,
          lastPage,
          total: posts.length,
          prev: n === 2 ? "/blog" : `/blog/page/${n - 1}`,
          next: n < lastPage ? `/blog/page/${n + 1}` : null,
        } satisfies PageProp,
      },
    });
  }
  return paths;
};

type Props = { page: PageProp };

const { page } = Astro.props as Props;

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" },
  { name: `Page ${page.currentPage}`, url: `/blog/page/${page.currentPage}` },
];
---

<BaseLayout
  title={`Blog — Page ${page.currentPage}`}
  description={`Page ${page.currentPage} of ${page.lastPage} from ${SITE.title}.`}
  breadcrumbs={breadcrumbs}
>
  <header class="mb-10 max-w-2xl">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Blog</h1>
    <p class="mt-3 text-lg text-[color:var(--muted)]">
      Page {page.currentPage} of {page.lastPage}
    </p>
  </header>

  <div class="grid gap-6 sm:grid-cols-2">
    {page.data.map((post) => <PostCard post={post} />)}
  </div>

  <nav
    aria-label="Pagination"
    class="mt-12 flex items-center justify-between border-t border-[color:var(--border)] pt-6 text-sm"
  >
    {
      page.prev ? (
        <a
          rel="prev"
          href={page.prev}
          class="inline-flex items-center gap-2 rounded-md px-3 py-2 font-medium text-[color:var(--fg)] transition hover:bg-slate-100 dark:hover:bg-slate-800"
        >
          <span aria-hidden="true">←</span> Newer
        </a>
      ) : (
        <span class="text-[color:var(--muted)]/60">← Newer</span>
      )
    }
    <span class="text-[color:var(--muted)]">
      Page <strong class="text-[color:var(--fg)]">{page.currentPage}</strong> of {page.lastPage}
    </span>
    {
      page.next ? (
        <a
          rel="next"
          href={page.next}
          class="inline-flex items-center gap-2 rounded-md px-3 py-2 font-medium text-[color:var(--fg)] transition hover:bg-slate-100 dark:hover:bg-slate-800"
        >
          Older <span aria-hidden="true">→</span>
        </a>
      ) : (
        <span class="text-[color:var(--muted)]/60">Older →</span>
      )
    }
  </nav>
</BaseLayout>
