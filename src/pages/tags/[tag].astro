---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostRow from "~/components/PostRow.astro";
import { getAllTags, getPostsByTag } from "~/lib/posts";
import { tagLabel, BRAND } from "~/consts";

export const prerender = true;

export async function getStaticPaths() {
  const counts = await getAllTags();
  const out: { params: { tag: string }; props: { tag: string } }[] = [];
  for (const [tag] of counts) out.push({ params: { tag }, props: { tag } });
  return out;
}

const { tag } = Astro.props;
const posts = await getPostsByTag(tag);
const label = tagLabel(tag);
---

<BaseLayout title={`${label} · ${BRAND}`} description={`${label} etiketli yazılar.`}>
  <section class="blog-head">
    <div class="shell">
      <div class="breadcrumbs" style="margin-bottom: 16px;">
        <a href="/">~</a>
        <span>/</span>
        <a href="/tags">tags</a>
        <span>/</span>
        <span style="color: var(--fg);">{tag}</span>
      </div>
      <span class="eyebrow">/etiket — {posts.length} yazı</span>
      <h1>{label}</h1>
      <p>"{label}" etiketli yazıların tamamı. En yeni en üstte.</p>
    </div>
  </section>

  <div class="shell">
    <div class="postlist" style="padding-bottom: 64px;">
      {posts.map((p, i) => <PostRow post={p} index={i} />)}
    </div>
  </div>
</BaseLayout>
