---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAllTags } from "~/lib/posts";
import { tagLabel, BRAND } from "~/consts";

export const prerender = true;

const counts = await getAllTags();
const tags = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title={`Etiketler · ${BRAND}`} description="Yazıların etiketlere göre dağılımı.">
  <section class="shell">
    <div class="tag-cloud">
      <span class="eyebrow">/etiketler — {tags.length} adet</span>
      <h1>Konuya göre.</h1>
      <p class="sub">
        Yazıları sınıflandırırken kendime dürüst olmaya çalıştım. Üç beş etiket, çok değil.
      </p>
      <div class="tag-grid">
        {tags.map(([slug, n]) => (
          <a href={`/tags/${slug}`} class="tag-cell">
            <div>
              <div style="display: flex; align-items: center; gap: 6px; color: var(--muted-2); font-family: var(--font-mono); font-size: 11px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18"/></svg>
                {slug}
              </div>
              <div class="name" style="margin-top: 8px;">{tagLabel(slug)}</div>
            </div>
            <span class="count tabular">{String(n).padStart(2, "0")} yazı</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
