---
export const prerender = true;

import BaseLayout from "~/layouts/BaseLayout.astro";
import Search from "~/components/Search.astro";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Search", url: "/search" },
];
---

<BaseLayout
  title="Search"
  description="Search every post on the blog."
  breadcrumbs={breadcrumbs}
  noindex
>
  <div class="mx-auto max-w-2xl">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Search</h1>
    <p class="mt-3 text-lg text-[color:var(--muted)]">
      Instant, client-side full-text search powered by Pagefind.
    </p>
    <div class="mt-8">
      <Search />
    </div>
  </div>
</BaseLayout>
