---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostRow from "~/components/PostRow.astro";
import { getAllTags, getPostsByTag, getPostUrl } from "~/lib/posts";
import { tagLabel, SITE, BRAND } from "~/consts";
import { LOCALES, type Locale, useTranslations, localePath } from "~/i18n";
import {
  buildBreadcrumbEntity,
  buildCollectionPageEntity,
  buildItemListEntity,
} from "~/lib/schema";

export const prerender = true;

export async function getStaticPaths() {
  const out: Array<{ params: { lang: Locale; tag: string }; props: { locale: Locale; tag: string } }> = [];
  for (const lang of LOCALES) {
    const counts = await getAllTags(lang);
    for (const [tag] of counts) out.push({ params: { lang, tag }, props: { locale: lang, tag } });
  }
  return out;
}

const { locale, tag } = Astro.props;
const t = useTranslations(locale);
const posts = await getPostsByTag(tag, locale);
const label = tagLabel(tag, locale);
const homeHref = localePath(locale, "/");
const tagsHref = localePath(locale, "/tags");

const siteOrigin = Astro.site ?? new URL(SITE.url);
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const description = t.tagDetail.descriptionMeta(label);
const jsonLd = [
  buildBreadcrumbEntity(
    [
      { name: t.nav.home, url: new URL(homeHref, siteOrigin).toString() },
      { name: t.tagsIndex.title, url: new URL(tagsHref, siteOrigin).toString() },
      { name: label, url: canonicalUrl },
    ],
    canonicalUrl,
  ),
  buildItemListEntity(
    posts.map((p) => ({
      name: p.data.title,
      url: getPostUrl(p),
      description: p.data.description,
      datePublished: p.data.pubDate.toISOString(),
    })),
    canonicalUrl,
  ),
  buildCollectionPageEntity(canonicalUrl, locale, {
    name: label,
    description,
  }),
];
---

<BaseLayout
  locale={locale}
  title={`${label} · ${BRAND}`}
  description={description}
  altPath={`/tags/${tag}`}
  jsonLd={jsonLd}
>
  <section class="blog-head">
    <div class="shell">
      <div class="breadcrumbs" style="margin-bottom: 16px;">
        <a href={homeHref}>~</a>
        <span>/</span>
        <a href={tagsHref}>{t.tagDetail.breadcrumb}</a>
        <span>/</span>
        <span style="color: var(--fg);">{tag}</span>
      </div>
      <span class="eyebrow">{t.tagDetail.eyebrow(posts.length)}</span>
      <h1>{label}</h1>
      <p>{t.tagDetail.lede(label)}</p>
    </div>
  </section>

  <div class="shell">
    <div class="postlist" style="padding-bottom: 64px;">
      {posts.map((p, i) => <PostRow post={p} index={i} locale={locale} />)}
    </div>
  </div>
</BaseLayout>
