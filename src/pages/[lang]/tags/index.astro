---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAllTags } from "~/lib/posts";
import { tagLabel, SITE, BRAND } from "~/consts";
import { LOCALES, type Locale, useTranslations, localePath } from "~/i18n";
import {
  buildBreadcrumbEntity,
  buildCollectionPageEntity,
  buildItemListEntity,
} from "~/lib/schema";

export const prerender = true;

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);

const counts = await getAllTags(locale);
const tags = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);

const siteOrigin = Astro.site ?? new URL(SITE.url);
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const jsonLd = [
  buildBreadcrumbEntity(
    [
      { name: t.nav.home, url: new URL(localePath(locale, "/"), siteOrigin).toString() },
      { name: t.tagsIndex.title, url: canonicalUrl },
    ],
    canonicalUrl,
  ),
  buildItemListEntity(
    tags.map(([slug]) => ({
      name: tagLabel(slug, locale),
      url: localePath(locale, `/tags/${slug}`),
    })),
    canonicalUrl,
  ),
  buildCollectionPageEntity(canonicalUrl, locale, {
    name: t.tagsIndex.title,
    description: t.tagsIndex.descriptionMeta,
  }),
];
---

<BaseLayout
  locale={locale}
  title={`${t.tagsIndex.title} · ${BRAND}`}
  description={t.tagsIndex.descriptionMeta}
  altPath="/tags"
  jsonLd={jsonLd}
>
  <section class="shell">
    <div class="tag-cloud">
      <span class="eyebrow">{t.tagsIndex.eyebrow(tags.length)}</span>
      <h1>{t.tagsIndex.heading}</h1>
      <p class="sub">
        {t.tagsIndex.lede}
      </p>
      <div class="tag-grid">
        {tags.map(([slug, n]) => (
          <a href={localePath(locale, `/tags/${slug}`)} class="tag-cell">
            <div>
              <div style="display: flex; align-items: center; gap: 6px; color: var(--muted-2); font-family: var(--font-mono); font-size: 11px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18"/></svg>
                {slug}
              </div>
              <div class="name" style="margin-top: 8px;">{tagLabel(slug, locale)}</div>
            </div>
            <span class="count tabular">{String(n).padStart(2, "0")} {t.tagsIndex.postsSuffix}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
