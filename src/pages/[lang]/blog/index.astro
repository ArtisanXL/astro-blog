---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostRow from "~/components/PostRow.astro";
import { getPublishedPosts, getAllTags, getPostUrl } from "~/lib/posts";
import { tagLabel, SITE, BRAND } from "~/consts";
import { LOCALES, type Locale, useTranslations, localePath } from "~/i18n";
import {
  buildBlogEntity,
  buildBreadcrumbEntity,
  buildItemListEntity,
} from "~/lib/schema";

export const prerender = true;

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);

const posts = await getPublishedPosts(locale);
const tagCounts = await getAllTags(locale);
const topTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

const siteOrigin = Astro.site ?? new URL(SITE.url);
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const jsonLd = [
  buildBreadcrumbEntity(
    [
      { name: t.nav.home, url: new URL(localePath(locale, "/"), siteOrigin).toString() },
      { name: t.blogIndex.title, url: canonicalUrl },
    ],
    canonicalUrl,
  ),
  buildItemListEntity(
    posts.slice(0, 10).map((p) => ({
      name: p.data.title,
      url: getPostUrl(p),
      description: p.data.description,
      datePublished: p.data.pubDate.toISOString(),
    })),
    canonicalUrl,
  ),
  buildBlogEntity(canonicalUrl, locale, {
    name: t.blogIndex.title,
    description: t.blogIndex.descriptionMeta,
  }),
];
---

<BaseLayout
  locale={locale}
  title={`${t.blogIndex.title} · ${BRAND}`}
  description={t.blogIndex.descriptionMeta}
  altPath="/blog"
  jsonLd={jsonLd}
>
  <section class="blog-head">
    <div class="shell">
      <span class="eyebrow">{t.blogIndex.eyebrow(posts.length)}</span>
      <h1>{t.blogIndex.heading}</h1>
      <p>{t.blogIndex.lede}</p>
    </div>
  </section>

  <div class="shell">
    <div class="filter-bar" id="filter-bar">
      <div class="filter-chips">
        <button class="tag active" data-filter-tag="" type="button">{t.blogIndex.filterAll} · {posts.length}</button>
        {topTags.map(([slug, n]) => (
          <button class="tag" data-filter-tag={slug} type="button">{tagLabel(slug, locale)} · {n}</button>
        ))}
        <a href={localePath(locale, "/tags")} class="tag" style="border-style: dashed;">{t.blogIndex.filterAllMore}</a>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <div class="search-box">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
          <input id="search-input" type="search" placeholder={t.blogIndex.searchPlaceholder} />
          <kbd>⌘K</kbd>
        </div>
      </div>
    </div>

    <div class="postlist" id="postlist" style="padding-bottom: 64px;">
      {posts.map((p, i) => (
        <PostRow post={p} index={i} locale={locale} />
      ))}
    </div>
    <div id="empty-state" class="empty" style="display: none;">{t.blogIndex.emptyState}</div>
  </div>
</BaseLayout>

<script is:inline>
  function bindBlogFilter() {
    const input = document.getElementById("search-input");
    const rows = Array.from(document.querySelectorAll("#postlist .postrow"));
    const chips = document.querySelectorAll("[data-filter-tag]");
    const empty = document.getElementById("empty-state");
    if (!input || !rows.length) return;

    let activeTag = "";
    let q = "";

    function apply() {
      let visible = 0;
      rows.forEach((row) => {
        const tags = (row.dataset.tags || "").split(",");
        const title = (row.dataset.title || "") + " " + tags.join(" ");
        const matchTag = !activeTag || tags.includes(activeTag);
        const matchQ = !q || title.toLowerCase().includes(q.toLowerCase());
        const show = matchTag && matchQ;
        row.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? "" : "none";
    }

    input.addEventListener("input", (e) => { q = e.target.value; apply(); });
    chips.forEach((c) => {
      c.addEventListener("click", () => {
        const t = c.dataset.filterTag || "";
        activeTag = activeTag === t ? "" : t;
        chips.forEach((cc) => cc.classList.toggle("active", (cc.dataset.filterTag || "") === activeTag || (!activeTag && (cc.dataset.filterTag || "") === "")));
        apply();
      });
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        input.focus();
      }
    });
  }
  bindBlogFilter();
  document.addEventListener("astro:after-swap", bindBlogFilter);
</script>
