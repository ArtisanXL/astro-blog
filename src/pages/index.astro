---
import BaseLayout from "~/layouts/BaseLayout.astro";
import FeaturedCard from "~/components/FeaturedCard.astro";
import PostRow from "~/components/PostRow.astro";
import { getPublishedPosts, getFeaturedPosts } from "~/lib/posts";
import { SITE } from "~/consts";

export const prerender = true;

const featured = (await getFeaturedPosts()).slice(0, 2);
const recent = (await getPublishedPosts()).slice(0, 8);
---

<BaseLayout>
  <section class="hero">
    <div class="shell">
      <div class="hero-meta">
        <span class="dot"></span>
        <span class="eyebrow">Şu an yazıyor</span>
        <span style="color: var(--muted-2);">·</span>
        <span class="eyebrow tabular">edge'den, Türkiye'den</span>
      </div>
      <h1 class="hero-title">
        Edge'den Laravel, paketler ve <em>gönderme</em> notları.
      </h1>
      <p class="hero-sub">
        Selam, ben {SITE.author.name}. Bir uçtan bir uca Laravel yazıyorum, ara sıra React ve Flutter'a sapıyorum,
        üç beş paket yayınladım. Burası ortada bıraktığım notların — denedim, çalıştı, ya da çalışmadı diye —
        durduğu yer.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/blog">
          Tüm yazılar
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a class="btn" href="/about">Hakkımda</a>
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="section" style="padding-top: 64px;">
      <div class="shell">
        <div class="section-head">
          <div>
            <span class="eyebrow">Öne çıkan</span>
            <h2>Bu ay en çok zaman harcadıklarım</h2>
          </div>
          <a href="/blog" class="section-link">
            Hepsini gör
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="featured-grid">
          {featured.map((p, i) => <FeaturedCard post={p} index={i} total={featured.length} />)}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="eyebrow">Akış</span>
          <h2>Son yazılar</h2>
        </div>
        <a href="/blog" class="section-link">
          Arşiv
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="postlist">
        {recent.map((p, i) => <PostRow post={p} index={i} />)}
      </div>
    </div>
  </section>

  <section>
    <div class="shell">
      <div class="about-strip">
        <div class="about-cell">
          <span class="eyebrow">/şu sıralar</span>
          <h3>Türkiye'den edge'e bir şeyler taşıyorum.</h3>
          <p>
            Şu anda küçük bir SaaS için Laravel + Workers tabanlı bir backend yazıyorum.
            Sürpriz şekilde stateful kalan kısımlar var, onları çözmeye çalışıyorum.
          </p>
          <p><a class="link" href="/about">Tam hikâyenin tamamı</a></p>
        </div>
        <div class="about-cell">
          <span class="eyebrow">/teknoloji</span>
          <ul>
            <li><span class="k">Backend</span><span class="v">Laravel 11 · PHP 8.4</span></li>
            <li><span class="k">Frontend</span><span class="v">Livewire 3 · React 19</span></li>
            <li><span class="k">Edge</span><span class="v">Cloudflare Workers</span></li>
            <li><span class="k">DB</span><span class="v">PostgreSQL · D1</span></li>
            <li><span class="k">Editör</span><span class="v">Helix · Zed</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
